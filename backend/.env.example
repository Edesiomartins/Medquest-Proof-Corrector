DATABASE_URL=postgresql://user:password@localhost/medquest_corrector
REDIS_URL=redis://localhost:6379/0

# Segredos (produção: usar gestor de secrets)
OPENROUTER_API_KEY=
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Origens do frontend (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Uploads locais (pasta criada automaticamente)
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=40

# Importação CSV de alunos
MAX_CSV_MB=5
MAX_CSV_ROWS=2000
