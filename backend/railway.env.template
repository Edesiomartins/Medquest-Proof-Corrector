# =============================================================================
# Railway — variáveis do BACKEND (FastAPI) e do WORKER (Celery)
# =============================================================================
# Como usar:
# 1. No Railway, abra cada serviço (API e Worker) → Variables → Raw Editor
# 2. Cole as linhas abaixo e substitua os placeholders
# 3. DATABASE_URL e REDIS_URL: Variables → Variable Reference → Postgres / Redis
# =============================================================================

# URL pública deste backend (só documentação — use no frontend como NEXT_PUBLIC_API_URL):
#   https://medquest-proof-corrector-api.up.railway.app/api/v1

# --- Obrigatórias para subir a API e o pipeline ---
DATABASE_URL=<postgresql do Railway – referência ao plugin Postgres>
REDIS_URL=<redis do Railway – referência ao plugin Redis>

# --- CORS: somente origem(s) do FRONTEND no Railway (serviço Next.js), com https://
# NÃO coloque aqui a URL da API (medquest-proof-corrector-api.up.railway.app), a menos
# que o HTML/JS seja servido desse mesmo host.
# Exemplo:
#   CORS_ORIGINS=https://medquest-proof-corrector-web.up.railway.app
# Várias origens: separadas por vírgula, sem espaço, sem barra no final.
CORS_ORIGINS=https://COLOQUE-AQUI-A-URL-DO-FRONTEND-RAILWAY

# --- LLM (correção) — preencha quando for usar OpenRouter ---
OPENROUTER_API_KEY=

# --- OCR Azure (Document Intelligence) — opcional até ligar o OCR ---
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# --- Armazenamento de PDFs no disco do container (efêmero entre deploys) ---
UPLOAD_DIR=/tmp/medquest_uploads
MAX_UPLOAD_MB=40

# --- Limites da importação CSV de alunos ---
MAX_CSV_MB=5
MAX_CSV_ROWS=2000
